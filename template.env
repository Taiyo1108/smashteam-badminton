# Database Connection (Supabase/PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/database

# JWT Secret for Token Signing
JWT_SECRET=your_jwt_secret_here

# Backend Server Port
PORT=5000

# Club Verification PIN for Old Members Account Activation
CLUB_VERIFY_PIN=123456

# Cloudinary Credentials (for Media Management)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Background Music URL (BGM) - Optional, falls back to synthwave loop if not defined
NEXT_PUBLIC_BGM_URL=https://res.cloudinary.com/your_cloud_name/video/upload/v1/bgm.mp3

# ==========================================
# CẤU HÌNH GỬI EMAIL (RESEND)
# ==========================================
# Khóa API của Resend (Đăng ký miễn phí tại https://resend.com)
RESEND_API_KEY=re_your_api_key_here
